# Reverse proxy Nginx : redirige ton domaine vers l'app Next.js (port 3000).
# À copier dans /etc/nginx/sites-available/siteperso puis activer (voir DEPLOY.md).
# Remplace ton-domaine.com par ton vrai domaine.

server {
    listen 80;
    listen [::]:80;
    server_name ton-domaine.com www.ton-domaine.com;

    # Taille max des requêtes (formulaire de contact, etc.)
    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}

# Après avoir lancé certbot (HTTPS), il ajoutera automatiquement un bloc
# server { listen 443 ssl; ... } et redirigera le port 80 vers 443.
